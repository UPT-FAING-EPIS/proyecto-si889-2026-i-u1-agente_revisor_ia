# Recomendado: usar proxy interno de Next.js para evitar CORS y mixed content.
NEXT_PUBLIC_BACKEND_URL=/backend

# Si se despliega en GitHub Pages, usa la URL pública del backend (ej. https://api.tu-dominio.com)
# y define el basePath del repositorio si se requiere.
# NEXT_PUBLIC_BACKEND_URL=https://api.tu-dominio.com
# NEXT_PUBLIC_BASE_PATH=proyecto-si889-2026-i-u1-agente_revisor_ia

# URL interna que usa Next.js para reenviar peticiones al backend FastAPI.
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
